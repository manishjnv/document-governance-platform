# T-1003: Production environment configuration
# DO NOT commit secrets to git - use secure secret management (Vault, AWS Secrets Manager, etc.)

# Database
DATABASE_URL=postgresql+asyncpg://edgp_user:${DB_PASSWORD}@postgres.edgp-prod.svc.cluster.local:5432/edgp_prod
DB_USER=edgp_user
DB_NAME=edgp_prod
DB_POOL_SIZE=20
DB_POOL_RECYCLE=3600

# Redis
REDIS_URL=redis://:${REDIS_PASSWORD}@redis.edgp-prod.svc.cluster.local:6379/0
REDIS_CACHE_TTL=3600

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=info

# Security
SECRET_KEY=${SECRET_KEY}
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS & Hosts
CORS_ORIGINS=https://edgp.example.com,https://app.edgp.example.com
ALLOWED_HOSTS=edgp.example.com,api.edgp.example.com

# Storage
STORAGE_TYPE=s3  # local | s3 | azure
S3_BUCKET=${S3_BUCKET}
S3_REGION=${S3_REGION}
S3_ACCESS_KEY=${S3_ACCESS_KEY}
S3_SECRET_KEY=${S3_SECRET_KEY}

# LLM Integration
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}

# Monitoring
SENTRY_DSN=${SENTRY_DSN}
LOG_FORMAT=json

# AI Configuration
AI_AGENT_TIMEOUT=60
AI_AGENT_RETRY_ATTEMPTS=2
AI_MODEL=claude-3-5-sonnet-20241022

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Document Processing
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_FILE_TYPES=pdf,docx

# Deployment
ENVIRONMENT=production
VERSION=1.0.0
