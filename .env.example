# ========================================
# Database Configuration
# ========================================
DATABASE_URL=postgresql+asyncpg://edgp_user:edgp_password@localhost:5432/edgp_dev
DATABASE_ECHO=false

# ========================================
# Redis Configuration
# ========================================
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# ========================================
# API Configuration
# ========================================
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
API_LOG_LEVEL=INFO

# ========================================
# Authentication
# ========================================
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# Azure AD / Entra ID (optional)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AZURE_AD_REDIRECT_URL=http://localhost:3000/api/auth/callback

# ========================================
# AI / LLM Configuration
# ========================================
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo

# AI behavior
AI_MAX_RETRIES=3
AI_TIMEOUT_SECONDS=60
AI_REQUEST_LOGGING=true

# ========================================
# Storage Configuration
# ========================================
# Local storage (development)
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/uploads

# AWS S3 (production)
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=edgp-documents

# Azure Blob (production)
# STORAGE_TYPE=azure
# AZURE_STORAGE_ACCOUNT_NAME=
# AZURE_STORAGE_ACCOUNT_KEY=
# AZURE_STORAGE_CONTAINER=documents

# ========================================
# Celery / Task Queue
# ========================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ========================================
# Frontend Configuration
# ========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=EDGP
NEXT_PUBLIC_APP_VERSION=1.0.0

# ========================================
# Security
# ========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOWED_HOSTS=localhost,127.0.0.1

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_LOGIN_ATTEMPTS=5

# ========================================
# Document Processing
# ========================================
MAX_DOCUMENT_SIZE_MB=50
ALLOWED_DOCUMENT_TYPES=pdf,docx
ENABLE_OCR=false

# ========================================
# Monitoring & Logging
# ========================================
SENTRY_DSN=
LOG_FILE_PATH=./logs/edgp.log
LOG_LEVEL=INFO

# ========================================
# Email Configuration (for notifications, future)
# ========================================
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@edgp.com

# ========================================
# Feature Flags
# ========================================
FEATURE_MULTI_DOCUMENT=false
FEATURE_CROSS_DOCUMENT_VALIDATION=false
FEATURE_CUSTOM_RULES=false
FEATURE_KNOWLEDGE_BASE=false

# ========================================
# Development Only
# ========================================
DEBUG=false
SEED_DATABASE=false
MOCK_AI_RESPONSES=false
